generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  SICK
  PERMIT
  ABSENT
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

enum Role {
  ADMIN
  TU
  GURU
  KEPALA_SEKOLAH
  ORANG_TUA
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  role         Role
  passwordHash String
  passwordSalt String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Teacher {
  id        String     @id @default(cuid())
  name      String
  email     String?    @unique
  phone     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  classrooms Classroom[]
}

model Classroom {
  id         String    @id @default(cuid())
  name       String
  level      String
  schoolYear String
  teacherId  String?
  teacher    Teacher?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  students   Student[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Admission {
  id            String         @id @default(cuid())
  childName      String
  birthDate      DateTime
  parentName     String
  parentPhone    String
  address        String?
  status         AdmissionStatus @default(PENDING)
  notes          String?
  approvedAt     DateTime?
  convertedToId  String?        @unique
  convertedTo    Student?       @relation("AdmissionToStudent", fields: [convertedToId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Student {
  id           String          @id @default(cuid())
  fullName     String
  nickName     String?
  birthDate    DateTime
  gender       String?
  guardianName String
  guardianPhone String
  address      String?
  status       StudentStatus   @default(ACTIVE)
  classroomId  String?
  classroom    Classroom?      @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  admission    Admission?      @relation("AdmissionToStudent")
  attendances  Attendance[]
  invoices     Invoice[]
  reports      DailyReport[]
  assessments  Assessment[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus
  note      String?
  createdAt DateTime         @default(now())

  @@index([studentId, date])
}

model Invoice {
  id          String        @id @default(cuid())
  code        String        @unique
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  periodMonth Int
  periodYear  Int
  amount      Int
  dueDate     DateTime
  status      InvoiceStatus @default(UNPAID)
  payments    Payment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([studentId, periodMonth, periodYear])
}

model Payment {
  id         String        @id @default(cuid())
  invoiceId  String
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount     Int
  method     PaymentMethod @default(TRANSFER)
  paidAt     DateTime
  note       String?
  createdAt  DateTime      @default(now())

  @@index([invoiceId, paidAt])
}

model DailyReport {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reportDate DateTime
  meals      String?
  nap        String?
  activities String
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([studentId, reportDate])
}

model Assessment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  periodLabel String
  social      Int
  cognitive   Int
  motoric     Int
  language    Int
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId, periodLabel])
}
